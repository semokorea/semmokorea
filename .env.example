# 세모코리아 어드민 환경변수
# 이 파일을 복사해서 .env 로 저장 후 값 입력
# cp .env.example .env

# ── Supabase (필수) ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT (필수) ──
# 랜덤 32자 이상 문자열: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── 서버 ──
PORT=3000
NODE_ENV=development

# ── 네이버 스마트스토어 API ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 쿠팡 API ──
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# ── 에이블리 API ──
ABLY_API_KEY=

# ── 지그재그 API ──
ZIGZAG_API_KEY=
